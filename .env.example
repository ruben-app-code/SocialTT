APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Opcional: token para POST /api/seed/assign-profile-photo (header X-Seeder-Token). Los seeders Artisan no lo necesitan.
# SEEDER_SERVICE_TOKEN=

# Opcional: id en topics para php artisan db:seed --class=UsersForTopicSeeder (ver README).
# SEED_TOPIC_ID=
# URL pública completa hasta la carpeta public (incluye subcarpeta si aplica).
# Debe coincidir con el host y esquema de la barra de direcciones (si entras por https://digitalizacion.test, pon eso aquí).
# Ejemplo XAMPP: http://localhost:99/web/socialtiktok/public
APP_URL=https://digitalizacion.test

# Dominios que Sanctum trata como "first party" (cookies de sesión / SPA). Incluye tu vhost local sin puerto si aplica.
# SANCTUM_STATEFUL_DOMAINS=digitalizacion.test,localhost,127.0.0.1,127.0.0.1:8000,::1

# Opcional: URL absoluta del JS de Livewire si no quieres derivarla de APP_URL.
# LIVEWIRE_ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apptracker
DB_USERNAME=root
DB_PASSWORD=

# file = menos dependencias en local (evita 419 si falla la tabla sessions o la BD). En producción puedes usar database.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# null = cookie válido solo en el host actual. No pongas un dominio distinto al de la barra de direcciones.
SESSION_DOMAIN=null
# Vacío o ausente: en HTTPS se fuerza cookie Secure (middleware ConfigureSessionForHttps). true/false fuerza explícito.
# SESSION_SECURE_COOKIE=
# SESSION_SAME_SITE=lax

# Si ves 419 al hacer login: APP_URL debe coincidir con la URL real (incl. https), php artisan config:clear,
# borrar cookies del sitio y volver a cargar /login. No mezcles http y https para la misma app.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
